# Environment variables for crop disease pipeline
# Copy this to .env and fill in your actual values

# ── Supabase (PostgreSQL DB) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# ── OpenWeatherMap (free tier — 60 calls/min) ─────────────────────
OPENWEATHER_API_KEY=your-openweathermap-api-key

# ── Sarvam Voice APIs (STT + TTS) ─────────────────────────────────
# Keep your key in SARVAM (primary) or SARVAM_API_KEY.
SARVAM=your-sarvam-api-key
# SARVAM_API_KEY=your-sarvam-api-key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_PATH=/speech-to-text
SARVAM_TTS_PATH=/text-to-speech
SARVAM_TIMEOUT_SECONDS=45

# ── Model Config ──────────────────────────────────────────────────
MODEL_PATH=mobilenetv2_plant.pth
PROTOCOLS_PATH=disease_protocols.json

# ── Server Config ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
